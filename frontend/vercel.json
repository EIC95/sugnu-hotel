{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/sugnu-hotel/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^(?!.*\\.(js|css|png|jpg|svg|ico|json)).*$",
      "dest": "/index.html"
    }
  ]
}